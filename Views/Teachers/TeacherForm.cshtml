@model Models.Teacher
@using Utilities

@{
    bool creating = Model.Id == 0;
    ViewBag.Title = creating ? "Prof - Ajout" : "Prof - Modification";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string session = NextSession.ShortCaption;
    string action = creating ? "Create" : "Edit";
}

@using (Html.BeginForm(action, "Teachers", FormMethod.Post,
        new { enctype = "multipart/form-data" }))
{
    @Html.HiddenFor(m => m.Id)
    @Html.HiddenFor(m => m.Code)

    <div class="panel">
        <div class="panel-heading">
            <div class="panel-title">
                <img src="~/Content/lio.png" class="panel-icon" />
                <span>@ViewBag.Title</span>
            </div>
            <div class="panel-commands">
                <button type="submit" title="Sauvegarder" class="btn-icon">
                    <i class="fa fa-check-circle" style="color:#007bff;"></i>
                </button>
                <a href="@(creating ? "/Teachers/Index" : "/Teachers/Details/" + Model.Id)"
                   title="Annuler"
                   class="btn-icon">
                    <i class="fa fa-times-circle" style="color:#007bff;"></i>
                </a>
            </div>
        </div>

        <details id="teacher_form_info" open>
            <summary>Informations - [@Model.Code]</summary>
            <div class="form-body">
                <div class="form-group">
                    <label>Prenom</label>
                    @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.FirstName)
                </div>
                <div class="form-group">
                    <label>Nom</label>
                    @Html.TextBoxFor(m => m.LastName, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.LastName)

                </div>
                <div class="form-group">
                    <label>Courriel</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Email)
                </div>
                <div class="form-group">
                    <label>Date d'embauche</label>
                    @Html.TextBoxFor(m => m.StartDate, "{0:yyyy-MM-dd}",
                        new { @class = "form-control", type = "date" })

                </div>
                <div class="form-group">
                    <label>Telephone</label>
                    @Html.TextBoxFor(m => m.Phone, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Phone)

                </div>
                <div class="form-group">
                    <label>Avatar</label>
                    <div>
                        <img src="@Model.Avatar" class="avatar-large"
                             onerror="this.src='/App_Assets/Users/no_avatar.png'" />
                    </div>
                    <input type="file" name="avatarFile" class="form-control" />
                </div>
            </div>
        </details>

        <details id="teacher_form_allocs" open>
            <summary>Allocation : Session @session</summary>
            @Helper.SelectionLists(
                "selectedCoursesId",
                (SelectList)ViewBag.AllocatedCourses,
                (SelectList)ViewBag.AllCourses
            )
        </details>

        <div class="panel-footer">
            <strong>Session courante : @session</strong>
        </div>
    </div>
}

@helper SelectionLists(string controlId, System.Web.Mvc.SelectList selectedItems, System.Web.Mvc.SelectList items, int size = 10)
{
    <div class="select_@controlId selectionsGrid">
        <select name='@controlId' size='@size.ToString()' multiple class='SelectedItems form-control'>
            @if (selectedItems != null)
            {
                foreach (var si in selectedItems)
                {
                    <option value='@si.Value'>
                        @si.Text
                    </option>
                }
            }
        </select>
        <div class="HorSelectionsCMD">
            <div class="AddSelection icon fa fa-circle-left" title="Ajouter">
            </div>
            <div class="RemoveSelection icon fa fa-circle-right" title="Retirer">
            </div>
            <div class="UnselectAll icon fa fa-times" data-toggle="tooltip" data-placement="bottom" title="Deselectionner">
            </div>
        </div>
        <div class="VerSelectionsCMD">
            <div class="AddSelection icon fa fa-circle-up" title="Ajouter">
            </div>
            <div class="RemoveSelection icon fa fa-circle-down" title="Retirer">
            </div>
            <div class="UnselectAll icon fa fa-times" title="Deselectionner">
            </div>
        </div>
        <select size='@size.ToString()' multiple class='UnselectedItems form-control'>
            @if (items != null)
            {
                foreach (var ui in items)
                {
                    if (selectedItems != null && selectedItems.Where(s => s.Value == ui.Value).FirstOrDefault() == null)
                    {
                        <option value='@ui.Value'>
                            @ui.Text
                        </option>
                    }
                }
            }
        </select>
    </div>
}
